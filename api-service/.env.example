# Application
PORT=3000
NODE_ENV=development

# Database (Prisma)
# PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# Example: postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# Better Auth Configuration
# A random secret key for session encryptions. You can generate one with `npx better-auth secret`
BETTER_AUTH_SECRET=your_secret_key_here

# The base URL of your application
BETTER_AUTH_URL=http://localhost:3000
