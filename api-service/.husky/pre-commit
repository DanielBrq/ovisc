#!/usr/bin/env sh
cd "$(dirname "$0")/.." || exit 1

echo "Running lint-staged (formats and lints only staged files)..."
pnpm exec lint-staged

echo "Running tests..."
pnpm run test

if [ $? -ne 0 ]; then
  echo "Tests failed. Please fix the tests before pushing."
  exit 1
fi
echo "Tests passed. Proceeding with push..."
